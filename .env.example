# Copy to .env and fill in your own values:  cp .env.example .env
# Do NOT commit the real .env (it is gitignored).

# MongoDB — local Docker Compose service
MONGO_URI=mongodb://localhost:27017

# Qdrant — local Docker Compose service
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Neo4j Aura (cloud) — free instance at https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-password>
NEO4J_DATABASE=neo4j
